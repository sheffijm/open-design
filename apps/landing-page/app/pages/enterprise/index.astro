  namePlaceholder: string;
  emailLabel: string;
  emailPlaceholder: string;
  companyLabel: string;
  companyPlaceholder: string;
  teamSizeLabel: string;
  teamSizePlaceholder: string;
  teamSizeOptions: TeamSizeOption[];
  budgetLabel: string;
  budgetHint: string;
  budgetPlaceholder: string;
  budgetOptions: TeamSizeOption[];
  useCaseLabel: string;
  useCaseHint: string;
  useCaseError: string;
  useCaseOptions: TeamSizeOption[];
  roleLabel: string;
  rolePlaceholder: string;
  messageLabel: string;
