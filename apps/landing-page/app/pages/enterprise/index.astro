  discordLabel: string;
  discordLinkText: string;
  submitLabel: string;
  submittingLabel: string;
  successTitle: string;
  successBody: string;
  errorMessage: string;
  privacyNote: string;
  optional: string;
  requiredError: string;
  emailError: string;
