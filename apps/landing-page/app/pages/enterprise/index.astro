const c = COPY[locale as keyof typeof COPY] ?? COPY.en;

const DISCORD_URL = 'https://discord.gg/egq3p2Wx8';

// Social-proof logo wall. Monochrome brand marks pulled at render time from the
// Simple Icons CDN (`cdn.simpleicons.org/<slug>/<hex>`) — no committed assets,
// and the single grey tint keeps the wall on-brand with the muted Atelier Zero
// palette (it warms to full ink on hover). Every slug below is verified to
// resolve on the CDN (Canva / Tencent / Figma are absent or unwanted here, so
// the set leans on design- and product-forward brands that do resolve). Kept
// dense (12 marks) so the wall reads full rather than sparse.
const LOGO_TINT = '8c8c8c';
const LOGOS: { name: string; slug: string }[] = [
  { name: 'Google', slug: 'google' },
  { name: 'Apple', slug: 'apple' },
  { name: 'Xiaomi', slug: 'xiaomi' },
  { name: 'ByteDance', slug: 'bytedance' },
  { name: 'Spotify', slug: 'spotify' },
  { name: 'Shopify', slug: 'shopify' },
  { name: 'Notion', slug: 'notion' },
  { name: 'Stripe', slug: 'stripe' },
  { name: 'Framer', slug: 'framer' },
  { name: 'Linear', slug: 'linear' },
  { name: 'Vercel', slug: 'vercel' },
  { name: 'Airbnb', slug: 'airbnb' },
];
const logoSrc = (slug: string) => `https://cdn.simpleicons.org/${slug}/${LOGO_TINT}`;

// Use-case demos — the homepage Labs showcase, lifted wholesale: the painting
// stage (`/lab-stage-art.webp`) with a magnifying mode Dock that swaps a
// floating artifact card / looping video in place. CSS lives in the shared
// `globals.css` (`.lab-stage` / `.lab-dock` / `.lab-artifact`); the interaction
// is driven by the ported `enhanceLabDock` / `enhanceLabSwitch` enhancers in
// the inline script below (mirrors `app/pages/index.astro`). Only 图片 / 视频
// are localized, matching the homepage; the rest keep their English labels.
const demoHref = (path: string) => localePath(locale, path);
const imageLabel = locale === 'zh' ? '图片' : locale === 'zh-tw' ? '圖片' : 'Image';
const videoLabel = locale === 'zh' ? '视频' : locale === 'zh-tw' ? '影片' : 'Video';
const DEMO_DOCK: {
  label: string;
  href: string;
  preview?: string;
  video?: string;
  wide?: boolean;
}[] = [
  { label: 'Prototype', href: demoHref('/plugins/templates/prototype/'), preview: '/lab-cards/prototype.webp?v=5' },
  { label: 'Live Artifact', href: demoHref('/plugins/templates/live-artifact/'), preview: '/lab-cards/live-artifact.webp?v=3' },
  { label: 'Slides', href: demoHref('/plugins/templates/deck/'), preview: '/lab-cards/slides.png?v=5' },
  { label: imageLabel, href: demoHref('/plugins/templates/image/'), preview: '/lab-cards/quest.webp?v=1', wide: true },
  { label: 'HyperFrames', href: demoHref('/plugins/templates/hyperframes/'), video: '/lab-hyperframes.mp4' },
  { label: videoLabel, href: demoHref('/plugins/templates/video/'), video: '/lab-video.mp4' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: c.metaTitle,
  description: c.metaDescription,
  url: new URL('/enterprise/', Astro.site).toString(),
};
---

<Layout title={c.metaTitle} description={c.metaDescription} active="enterprise" jsonLd={jsonLd}>
  <section class="ent-page" data-od-id="enterprise">
    <div class="ent-intro">
      <h1 class="ent-h1">{c.h1}</h1>
      <p class="ent-lead">{c.lead}</p>
      <ul class="ent-perks">
        {c.perks.map((perk) => (
          <li class="ent-perk">
            <span class="ent-perk__tick" aria-hidden="true">
              <svg viewBox="0 0 16 16" width="14" height="14" fill="none">
                <path d="M3.5 8.5l3 3 6-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <span>{perk}</span>
          </li>
        ))}
      </ul>

      {/* Discord community nudge — a friendly invite card (not a form field),
          the whole card links to the server. */}
      <a class="ent-discord" href={DISCORD_URL} target="_blank" rel="noopener noreferrer">
        <span class="ent-discord__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M19.27 5.33A16.6 16.6 0 0 0 15.1 4l-.2.4a14.5 14.5 0 0 1 3.7 1.19 12.7 12.7 0 0 0-10.95 0A14.6 14.6 0 0 1 11.36 4.4L11.16 4a16.6 16.6 0 0 0-4.18 1.33C4.1 9.61 3.32 13.78 3.71 17.9a16.7 16.7 0 0 0 5.06 2.56l.4-.56a9.8 9.8 0 0 1-1.6-.77l.39-.31a11.9 11.9 0 0 0 10.17 0l.4.31a9.8 9.8 0 0 1-1.61.77l.4.56a16.7 16.7 0 0 0 5.07-2.56c.46-4.78-.79-8.92-3.51-12.57ZM9.55 15.42c-.99 0-1.8-.92-1.8-2.05 0-1.12.8-2.04 1.8-2.04 1 0 1.82.93 1.8 2.04 0 1.13-.8 2.05-1.8 2.05Zm4.91 0c-.99 0-1.8-.92-1.8-2.05 0-1.12.8-2.04 1.8-2.04 1 0 1.82.93 1.8 2.04 0 1.13-.8 2.05-1.8 2.05Z"/></svg>
        </span>
        <span class="ent-discord__text">{c.discordLabel}</span>
        <span class="ent-discord__cta">
          {c.discordLinkText}
          <svg viewBox="0 0 16 16" width="13" height="13" fill="none" aria-hidden="true"><path d="M5 3h8v8M13 3 3.5 12.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </span>
      </a>

      <div class="ent-logos">
        <span class="ent-logos__title">{c.logosTitle}</span>
        <div class="ent-logos__grid">
          {LOGOS.map((logo) => (
            <span class="ent-logos__item">
              <img
                class="ent-logos__img"
                src={logoSrc(logo.slug)}
                alt={logo.name}
                width="88"
                height="26"
                loading="lazy"
                decoding="async"
              />
            </span>
          ))}
        </div>
      </div>
    </div>

    <div class="ent-card">
      <div class="ent-incentive">
        <span class="ent-incentive__badge" aria-hidden="true">
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M8 1.5l1.9 3.9 4.3.6-3.1 3 .7 4.3L8 11.3 4.3 13.3l.7-4.3-3.1-3 4.3-.6z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" /></svg>
        </span>
        <div class="ent-incentive__text">
          <span class="ent-incentive__title">{c.incentiveTitle}</span>
          <span class="ent-incentive__body">{c.incentiveBody}</span>
        </div>
      </div>
      <h2 class="ent-form-heading">{c.formHeading}</h2>
      <form class="ent-form" id="ent-form" novalidate>
        <div class="ent-field">
          <label class="ent-label" for="ent-name">{c.nameLabel} <span class="ent-req">*</span></label>
          <input class="ent-input" id="ent-name" name="name" type="text" required autocomplete="name" placeholder={c.namePlaceholder} />
          <p class="ent-field-error" id="ent-name-error" role="alert" hidden>{c.requiredError}</p>
        </div>

        <div class="ent-field">
          <label class="ent-label" for="ent-email">{c.emailLabel} <span class="ent-req">*</span></label>
          <input class="ent-input" id="ent-email" name="email" type="email" required autocomplete="email" placeholder={c.emailPlaceholder} />
          <p class="ent-field-error" id="ent-email-error" role="alert" hidden>{c.emailError}</p>
        </div>

        <div class="ent-row">
          <div class="ent-field">
            <label class="ent-label" for="ent-company">{c.companyLabel} <span class="ent-req">*</span></label>
            <input class="ent-input" id="ent-company" name="company" type="text" required autocomplete="organization" placeholder={c.companyPlaceholder} />
            <p class="ent-field-error" id="ent-company-error" role="alert" hidden>{c.requiredError}</p>
          </div>
          <div class="ent-field">
            <span class="ent-label" id="ent-team-size-label">{c.teamSizeLabel} <span class="ent-req">*</span></span>
            <div class="ent-cselect" data-cselect>
              <select class="ent-cselect__native" id="ent-team-size" name="teamSize" required tabindex="-1" aria-hidden="true">
                <option value="" disabled selected>{c.teamSizePlaceholder}</option>
                {c.teamSizeOptions.map((opt) => (
                  <option value={opt.value}>{opt.label}</option>
                ))}
              </select>
              <button type="button" class="ent-cselect__trigger" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="ent-team-size-label">
                <span class="ent-cselect__value is-placeholder" data-placeholder>{c.teamSizePlaceholder}</span>
                <span class="ent-select-chevron" aria-hidden="true">
                  <svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </span>
              </button>
              <ul class="ent-cselect__menu" role="listbox" aria-label={c.teamSizeLabel} hidden>
                {c.teamSizeOptions.map((opt) => (
                  <li class="ent-cselect__opt" role="option" data-value={opt.value} aria-selected="false" tabindex="-1">{opt.label}</li>
                ))}
              </ul>
            </div>
            <p class="ent-field-error" id="ent-team-size-error" role="alert" hidden>{c.requiredError}</p>
          </div>
        </div>

        <div class="ent-field">
          <span class="ent-label" id="ent-budget-label">{c.budgetLabel} <span class="ent-req">*</span> <span class="ent-optional">({c.budgetHint})</span></span>
          <div class="ent-cselect" data-cselect>
            <select class="ent-cselect__native" id="ent-budget" name="budget" required tabindex="-1" aria-hidden="true">
              <option value="" disabled selected>{c.budgetPlaceholder}</option>
              {c.budgetOptions.map((opt) => (
                <option value={opt.value}>{opt.label}</option>
              ))}
            </select>
            <button type="button" class="ent-cselect__trigger" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="ent-budget-label">
              <span class="ent-cselect__value is-placeholder" data-placeholder>{c.budgetPlaceholder}</span>
              <span class="ent-select-chevron" aria-hidden="true">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </span>
            </button>
            <ul class="ent-cselect__menu" role="listbox" aria-label={c.budgetLabel} hidden>
              {c.budgetOptions.map((opt) => (
                <li class="ent-cselect__opt" role="option" data-value={opt.value} aria-selected="false" tabindex="-1">{opt.label}</li>
              ))}
            </ul>
          </div>
          <p class="ent-field-error" id="ent-budget-error" role="alert" hidden>{c.requiredError}</p>
        </div>

        <div class="ent-field">
          <span class="ent-label">{c.useCaseLabel} <span class="ent-req">*</span> <span class="ent-optional">({c.useCaseHint})</span></span>
          <div class="ent-chips" role="group" aria-label={c.useCaseLabel}>
            {c.useCaseOptions.map((opt) => (
              <button type="button" class="ent-chip" data-value={opt.value} aria-pressed="false">{opt.label}</button>
            ))}
          </div>
          <p class="ent-field-error" id="ent-use-case-error" role="alert" hidden>{c.useCaseError}</p>
        </div>

        <div class="ent-field">
          <label class="ent-label" for="ent-role">{c.roleLabel} <span class="ent-optional">({c.optional})</span></label>
          <input class="ent-input" id="ent-role" name="role" type="text" autocomplete="organization-title" placeholder={c.rolePlaceholder} />
        </div>

        <div class="ent-field">
          <label class="ent-label" for="ent-message">{c.messageLabel} <span class="ent-optional">({c.optional})</span></label>
          <textarea class="ent-input ent-textarea" id="ent-message" name="message" rows="4" placeholder={c.messagePlaceholder}></textarea>
        </div>

        <button class="btn btn-primary ent-submit" type="submit" data-default-label={c.submitLabel} data-submitting-label={c.submittingLabel}>
          {c.submitLabel}
        </button>

        <p class="ent-privacy">{c.privacyNote}</p>
        <p class="ent-error" id="ent-error" role="alert" hidden>{c.errorMessage}</p>
      </form>

      <div class="ent-success" id="ent-success" hidden>
        <span class="ent-success__tick" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none"><path d="M5 12.5l4.5 4.5L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </span>
        <h2 class="ent-success__title">{c.successTitle}</h2>
        <p class="ent-success__body">{c.successBody}</p>
      </div>
    </div>
  </section>

  {/* Use-case showcase — the homepage Labs stage lifted wholesale: a painting
      canvas with a magnifying mode Dock that swaps the floating artifact card /
      looping video in place. Full-bleed `.lab-stage` (its centering math reads
      50% of the enclosing `.sub-main.container` content box, same as the
      homepage `.labs > .container`), so it must stay an unconstrained block. */}
  <section class="ent-demos" id="labs" data-od-id="demos">
    <div class="ent-demos__head">
      <span class="ent-demos__title">{c.demosTitle}</span>
      <p class="ent-demos__lead">{c.demosLead}</p>
    </div>
    <div class="lab-stage">
      {/* Floating artifact card, layered over the painting; the dock swaps its
          src and toggles `.is-visible` (see `enhanceLabSwitch`). */}
      <img class="lab-artifact" data-lab-artifact alt="" decoding="async" />
      {/* Video mode: the HyperFrames / 视频 tiles play this looping clip
          instead of a still card. */}
      <video
        class="lab-artifact lab-artifact-video"
        data-lab-video
        muted
        loop
        playsinline
        preload="metadata"
        aria-hidden="true"
      ></video>
      {/* macOS-style magnifying Dock — proximity magnify + click/auto-cycle
          preview swap, driven by the enhancers in the inline script. */}
      <div class="lab-dock" data-lab-dock>
        {DEMO_DOCK.map((item) => (
          <a
            class={item.wide ? 'lab-dock-item active' : 'lab-dock-item'}
            href={item.href}
            data-dock-item
            data-preview-src={item.video ? undefined : item.preview}
            data-preview-video={item.video}
            data-preview-wide={item.wide ? '' : undefined}
            data-preview-title={item.label}
            aria-label={item.label}
          >
            <span class="lab-dock-icon" aria-hidden="true"></span>
            <span class="lab-dock-label">{item.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const form = document.getElementById('ent-form');
      if (!form) return;
      const errorEl = document.getElementById('ent-error');
      const successEl = document.getElementById('ent-success');
      const submitBtn = form.querySelector('.ent-submit');
      const defaultLabel = submitBtn?.getAttribute('data-default-label') || 'Submit';
      const submittingLabel = submitBtn?.getAttribute('data-submitting-label') || defaultLabel;
      const useCaseError = document.getElementById('ent-use-case-error');
      const chips = Array.from(form.querySelectorAll('.ent-chip'));

      // Custom selects — a fully styled dropdown so we don't render the OS-native
      // popup. The real <select> stays in the DOM (hidden) as the form value and
      // validation source of truth; the listbox below just drives it and fires a
      // `change` so the existing per-field validation clears on pick.
      form.querySelectorAll('[data-cselect]').forEach((root) => {
        const native = root.querySelector('.ent-cselect__native');
        const trigger = root.querySelector('.ent-cselect__trigger');
        const valueEl = root.querySelector('.ent-cselect__value');
        const menu = root.querySelector('.ent-cselect__menu');
        const opts = Array.from(menu.querySelectorAll('.ent-cselect__opt'));
        if (!native || !trigger || !valueEl || !menu) return;

        const close = () => {
          menu.hidden = true;
          trigger.setAttribute('aria-expanded', 'false');
        };
        const open = () => {
          menu.hidden = false;
          trigger.setAttribute('aria-expanded', 'true');
          const current = opts.find((o) => o.getAttribute('aria-selected') === 'true');
          (current || opts[0])?.focus();
        };
        const pick = (opt) => {
          native.value = opt.getAttribute('data-value');
          valueEl.textContent = opt.textContent;
          valueEl.classList.remove('is-placeholder');
          opts.forEach((o) => o.setAttribute('aria-selected', o === opt ? 'true' : 'false'));
          native.dispatchEvent(new Event('change', { bubbles: true }));
          close();
          trigger.focus();
        };

        trigger.addEventListener('click', () => (menu.hidden ? open() : close()));
        trigger.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            open();
          }
        });
        opts.forEach((opt, i) => {
          opt.addEventListener('click', () => pick(opt));
          opt.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              pick(opt);
            } else if (e.key === 'ArrowDown') {
              e.preventDefault();
              (opts[i + 1] || opts[0]).focus();
            } else if (e.key === 'ArrowUp') {
              e.preventDefault();
              (opts[i - 1] || opts[opts.length - 1]).focus();
            } else if (e.key === 'Escape' || e.key === 'Tab') {
              close();
              if (e.key === 'Escape') trigger.focus();
            }
          });
        });
        document.addEventListener('click', (e) => {
          if (!root.contains(e.target)) close();
        });
      });

      // Inline validation — the form is `novalidate`, so we never trigger the
      // browser's native validation bubble; we show our own styled messages.
      const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      const fieldInput = (id) => document.getElementById('ent-' + id);
      const fieldErr = (id) => document.getElementById('ent-' + id + '-error');
      const setInvalid = (id, bad) => {
        const input = fieldInput(id);
        const err = fieldErr(id);
        if (input) input.classList.toggle('is-invalid', bad);
        if (err) err.hidden = !bad;
      };
      const validateField = (id) => {
        const input = fieldInput(id);
        if (!input) return true;
        const bad = id === 'email'
          ? !EMAIL_RE.test(input.value.trim())
          : input.value.trim() === '';
        setInvalid(id, bad);
        return !bad;
      };
      ['name', 'email', 'company'].forEach((id) => {
        const input = fieldInput(id);
        if (input) input.addEventListener('input', () => setInvalid(id, false));
      });
      ['team-size', 'budget'].forEach((id) => {
        const sel = fieldInput(id);
        if (sel) sel.addEventListener('change', () => setInvalid(id, false));
      });

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          const pressed = chip.getAttribute('aria-pressed') === 'true';
          chip.setAttribute('aria-pressed', pressed ? 'false' : 'true');
          if (useCaseError) useCaseError.hidden = true;
        });
      });

      // Lightweight analytics wrapper around the shared PostHog delegate
      // (window.__odTrack, installed by sub-page-layout). page_name matches the
      // server-derived pageNameFromPath('/enterprise/') = 'enterprise'.
      const track = (name, props) => {
        try {
          if (typeof window.__odTrack === 'function') {
            window.__odTrack(name, Object.assign(
              { page_name: 'enterprise', locale: (document.documentElement.lang || 'en').toLowerCase() },
              props || {},
            ));
          }
        } catch (e) {}
      };

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (errorEl) errorEl.hidden = true;
        if (useCaseError) useCaseError.hidden = true;

        let firstInvalid = null;
        const invalidFields = [];
        ['name', 'email', 'company', 'team-size', 'budget'].forEach((id) => {
          if (!validateField(id)) {
            invalidFields.push(id);
            if (!firstInvalid) firstInvalid = fieldInput(id);
          }
        });

        const useCases = chips
          .filter((chip) => chip.getAttribute('aria-pressed') === 'true')
          .map((chip) => chip.getAttribute('data-value'));
        if (useCases.length === 0) {
          invalidFields.push('use-case');
          if (useCaseError) useCaseError.hidden = false;
          if (!firstInvalid) firstInvalid = chips[0];
        }

        if (firstInvalid) {
          // Validation blocked the submit — record which fields so we can see
          // where the funnel leaks.
          track('lead_submit_invalid', { missing: invalidFields.join(',') });
          // A custom-select's real <select> is hidden, so focus its trigger.
          const focusTarget = firstInvalid.classList?.contains('ent-cselect__native')
            ? firstInvalid.parentElement.querySelector('.ent-cselect__trigger')
            : firstInvalid;
          if (focusTarget && typeof focusTarget.focus === 'function') focusTarget.focus();
          return;
        }

        const data = new FormData(form);
        const payload = {
          source: 'enterprise',
          name: String(data.get('name') || '').trim(),
          email: String(data.get('email') || '').trim(),
          company: String(data.get('company') || '').trim(),
          teamSize: String(data.get('teamSize') || '').trim(),
          budget: String(data.get('budget') || '').trim(),
          useCases,
          role: String(data.get('role') || '').trim(),
          message: String(data.get('message') || '').trim(),
          locale: document.documentElement.lang || 'en',
          pageUrl: location.href,
        };

        const leadProps = {
          team_size: payload.teamSize,
          budget: payload.budget,
          use_case_count: useCases.length,
        };
        track('lead_submit_attempt', leadProps);

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = submittingLabel;
        }

        try {
          const res = await fetch('/contact-sales', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          if (!res.ok) throw new Error('request_failed');
          track('lead_submit_success', leadProps);
          form.hidden = true;
          if (successEl) {
            successEl.hidden = false;
            successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        } catch (err) {
          track('lead_submit_failed', Object.assign({ reason: 'request_failed' }, leadProps));
          if (errorEl) errorEl.hidden = false;
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = defaultLabel;
          }
        }
      });
    })();

    /* Labs showcase — ported wholesale from `app/pages/index.astro` so the
       enterprise demo band behaves exactly like the homepage: a magnifying
       mode Dock that swaps the floating artifact card / looping video in place,
       auto-cycling while on screen and pausing on hover. Self-contained IIFE so
       it runs independently of the lead form above. */
    (() => {
      const labPrefersWebm = (() => {
        try {
          const v = document.createElement('video');
          return !!(v.canPlayType && v.canPlayType('video/webm; codecs="vp9"'));
        } catch (e) {
          return false;
        }
      })();
      const labClipSrc = (src) =>
        labPrefersWebm && /\.mp4$/i.test(src || '') ? src.replace(/\.mp4$/i, '.webm') : src;

      // Proximity-magnify dock (macOS-style) + lazy prefetch of the video clips.
      const enhanceLabDock = () => {
        const dock = document.querySelector('[data-lab-dock]');
        if (!dock) return;
        (function prefetchLabVideos() {
          const srcs = Array.from(dock.querySelectorAll('[data-preview-video]'))
            .map((el) => el.getAttribute('data-preview-video'))
            .filter(Boolean)
            .map(labClipSrc);
          if (srcs.length === 0) return;
          let done = false;
          const run = () => {
            if (done) return;
            done = true;
            srcs.forEach((src) => { try { fetch(src).catch(() => {}); } catch (e) {} });
          };
          if ('IntersectionObserver' in window) {
            const io = new IntersectionObserver((entries) => {
              if (entries.some((entry) => entry.isIntersecting)) {
                io.disconnect();
                run();
              }
            }, { rootMargin: '0px 0px 100% 0px' });
            io.observe(dock);
          } else if ('requestIdleCallback' in window) {
            requestIdleCallback(run, { timeout: 4000 });
          } else {
            setTimeout(run, 2500);
          }
        })();
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const items = Array.from(dock.querySelectorAll('[data-dock-item]'));
        if (items.length === 0) return;
        const MAX = 1.08;
        const DIST = 104;
        let ticking = false;
        const apply = (cursorX) => {
          const dockLeft = dock.getBoundingClientRect().left;
          const x = cursorX - dockLeft;
          for (const it of items) {
            const center = it.offsetLeft + it.offsetWidth / 2;
            const t = Math.max(0, 1 - Math.abs(x - center) / DIST);
            const lift = it.classList.contains('active') ? 'translateY(-20px) ' : '';
            it.style.transform = `${lift}scale(${(1 + (MAX - 1) * t).toFixed(3)})`;
          }
        };
        dock.addEventListener('mousemove', (event) => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            apply(event.clientX);
            ticking = false;
          });
        }, { passive: true });
        dock.addEventListener('mouseleave', () => {
          for (const it of items) it.style.transform = '';
        });
      };

      // The painting is the background; each dock tile floats its artifact
      // (`data-preview-src`) or plays its clip (`data-preview-video`) centered
      // over it. Auto-cycles 1→6 (10s each) while the stage is on screen.
      const enhanceLabSwitch = () => {
        const stage = document.querySelector('.lab-stage');
        const dock = document.querySelector('[data-lab-dock]');
        const artifact = document.querySelector('[data-lab-artifact]');
        const video = document.querySelector('[data-lab-video]');
        if (!stage || !dock || !artifact) return;
        const items = Array.from(dock.querySelectorAll('[data-dock-item]'));
        if (items.length === 0) return;
        const isBare = (src) => !src || src.indexOf('lab-stage-art') !== -1;

        for (const it of items) {
          const src = it.getAttribute('data-preview-src');
          if (!isBare(src)) {
            const pre = new Image();
            pre.src = src;
          }
        }

        const show = (it) => {
          const src = it.getAttribute('data-preview-src');
          const vsrc = it.getAttribute('data-preview-video');
          items.forEach((x) => x.classList.toggle('active', x === it));
          if (vsrc && video) {
            artifact.classList.remove('is-visible');
            const clip = labClipSrc(vsrc);
            if (video.getAttribute('src') !== clip) video.setAttribute('src', clip);
            video.classList.add('is-visible');
            try {
              video.currentTime = 0;
              const pr = video.play();
              if (pr && pr.catch) pr.catch(() => {});
            } catch (_) {}
            return;
          }
          if (video) {
            video.classList.remove('is-visible');
            try { video.pause(); } catch (_) {}
          }
          if (isBare(src)) {
            artifact.classList.remove('is-visible');
            return;
          }
          artifact.classList.toggle('is-wide', it.hasAttribute('data-preview-wide'));
          artifact.setAttribute('src', src);
          artifact.classList.add('is-visible');
        };

        const INTERVAL = 10000;
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        let idx = 0;
        let timer = null;
        const stop = () => {
          if (timer) {
            clearInterval(timer);
            timer = null;
          }
        };
        const start = () => {
          if (reduceMotion) return;
          stop();
          timer = setInterval(() => {
            idx = (idx + 1) % items.length;
            show(items[idx]);
          }, INTERVAL);
        };

        for (const it of items) {
          it.addEventListener('click', (event) => {
            event.preventDefault();
            idx = items.indexOf(it);
            show(it);
            start();
            // A real user pick (not the auto-cycle) — which use-case demo drew
            // interest. Uses the shared PostHog delegate directly (this enhancer
            // lives in its own IIFE, separate from the form's `track`).
            try {
              if (typeof window.__odTrack === 'function') {
                window.__odTrack('demo_click', {
                  page_name: 'enterprise',
                  locale: (document.documentElement.lang || 'en').toLowerCase(),
                  demo: it.getAttribute('data-preview-title') || '',
                });
              }
            } catch (e) {}
          });
        }

        show(items[0]);
        if (!reduceMotion) {
          stage.addEventListener('mouseenter', stop);
          stage.addEventListener('mouseleave', start);
          const io = new IntersectionObserver((entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                idx = 0;
                show(items[0]);
                start();
              } else {
                stop();
              }
            }
          }, { threshold: 0.3 });
          io.observe(stage);
        }
      };

      enhanceLabDock();
      enhanceLabSwitch();
    })();
  </script>

  <style>
