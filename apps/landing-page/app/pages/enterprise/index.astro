    /* ---------- early-access incentive ---------- */
    .ent-incentive {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 22px;
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid color-mix(in oklab, var(--line), var(--olive) 32%);
      background: color-mix(in oklab, var(--bone), var(--coral) 12%);
    }
    .ent-incentive__badge {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 26px;
      height: 26px;
      margin-top: 1px;
      border-radius: 999px;
      background: color-mix(in oklab, var(--bone), var(--coral) 26%);
      color: var(--olive, #218c00);
    }
    .ent-incentive__text {
      display: flex;
      flex-direction: column;
      gap: 3px;
    }
    .ent-incentive__title {
      font-size: 14px;
      font-weight: 700;
      color: var(--ink, #262626);
    }
    .ent-incentive__body {
      font-size: 13px;
      line-height: 1.55;
      color: var(--ink-soft, #434343);
    }

    /* ---------- Discord opt-in ---------- */
    /* Left-column Discord invite — a friendly nudge card (not a form field),
       sits between the perks list and the logo wall. The whole card links to
       the server. */
    .ent-discord {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 24px;
      padding: 14px 16px;
      border-radius: 14px;
      border: 1px solid var(--line, #d9d9d9);
      background: var(--bone, #fff);
      text-decoration: none;
      transition: border-color 0.16s ease, background 0.16s ease,
        transform 0.16s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.16s ease;
    }
    .ent-discord:hover {
      border-color: color-mix(in oklab, var(--line), #5865f2 55%);
      background: color-mix(in oklab, var(--bone), #5865f2 6%);
      transform: translateY(-1px);
      box-shadow: 0 8px 20px -14px rgba(88, 101, 242, 0.55);
    }
    .ent-discord__icon {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: #5865f2;
      color: #fff;
    }
    .ent-discord__text {
      flex: 1 1 auto;
      font-size: 13.5px;
      line-height: 1.5;
      color: var(--ink-soft, #434343);
    }
    .ent-discord__cta {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 13px;
      font-weight: 600;
      white-space: nowrap;
      color: #5865f2;
    }
    .ent-form {
      flex-direction: column;
      gap: 18px;
    }
    /* `:not([hidden])` so toggling the `hidden` attr in JS actually hides the
       node — a bare `display: flex` would override the UA `[hidden]` rule. */
    .ent-form:not([hidden]) {
      display: flex;
    }
    .ent-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }
    .ent-field {
      display: flex;
      flex-direction: column;
      gap: 8px;
      min-width: 0;
    }
    .ent-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--ink, #262626);
    }
    .ent-req {
      color: var(--olive, #218c00);
    }
    .ent-optional {
      font-weight: 400;
      color: var(--ink-faint, #8c8c8c);
    }
    .ent-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .ent-chip {
      font-family: var(--body);
      font-size: 13px;
      font-weight: 500;
      line-height: 1;
      color: var(--ink-soft, #434343);
      background: var(--paper, #fafafa);
      border: 1px solid var(--line, #d9d9d9);
      border-radius: 999px;
      padding: 9px 14px;
      cursor: pointer;
      transition: color 0.16s ease, background 0.16s ease, border-color 0.16s ease;
      white-space: nowrap;
    }
    .ent-chip:hover {
      border-color: var(--line-hover, #bfbfbf);
    }
    .ent-chip[aria-pressed='true'] {
      color: var(--olive, #218c00);
      background: color-mix(in oklab, var(--bone), var(--coral) 18%);
      border-color: color-mix(in oklab, var(--line), var(--olive) 45%);
    }
    .ent-field-error {
      margin: 2px 0 0;
      font-size: 12px;
      line-height: 1.4;
      color: #c0392b;
    }
    .ent-input {
      width: 100%;
      font-family: var(--body);
      font-size: 15px;
      color: var(--ink, #262626);
      background: var(--paper, #fafafa);
      border: 1px solid var(--line, #d9d9d9);
      border-radius: 10px;
      padding: 11px 14px;
      transition: border-color 0.16s ease, box-shadow 0.16s ease, background 0.16s ease;
      appearance: none;
    }
    .ent-input::placeholder {
      color: var(--ink-faint, #8c8c8c);
    }
    .ent-input:hover {
      border-color: var(--line-hover, #bfbfbf);
    }
    .ent-input:focus {
      outline: none;
      background: var(--bone, #fff);
      border-color: var(--olive, #218c00);
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--bone), var(--coral) 26%);
    }
    .ent-input.is-invalid {
      border-color: #c0392b;
      background: var(--bone, #fff);
    }
    .ent-input.is-invalid:focus {
      border-color: #c0392b;
      box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.14);
    }
    .ent-textarea {
      resize: vertical;
      min-height: 96px;
      line-height: 1.5;
    }
    /* ---------- custom select (no native popup) ---------- */
    .ent-cselect {
      position: relative;
    }
    /* The real <select> stays in the DOM as form value + validation source, but
       is fully hidden so the OS-native dropdown never appears. */
    .ent-cselect__native {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
      border: 0;
    }
    .ent-cselect__trigger {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      font-family: var(--body);
      font-size: 15px;
      color: var(--ink, #262626);
      text-align: left;
      background: var(--paper, #fafafa);
      border: 1px solid var(--line, #d9d9d9);
      border-radius: 10px;
      padding: 11px 14px;
      cursor: pointer;
      transition: border-color 0.16s ease, box-shadow 0.16s ease, background 0.16s ease;
    }
    .ent-cselect__trigger:hover {
      border-color: var(--line-hover, #bfbfbf);
    }
    .ent-cselect__trigger:focus-visible,
    .ent-cselect__trigger[aria-expanded='true'] {
      outline: none;
      background: var(--bone, #fff);
      border-color: var(--olive, #218c00);
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--bone), var(--coral) 26%);
    }
    .ent-cselect__native.is-invalid ~ .ent-cselect__trigger {
      border-color: #c0392b;
      background: var(--bone, #fff);
    }
    .ent-cselect__native.is-invalid ~ .ent-cselect__trigger:focus-visible,
    .ent-cselect__native.is-invalid ~ .ent-cselect__trigger[aria-expanded='true'] {
      border-color: #c0392b;
      box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.14);
    }
    .ent-cselect__value {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .ent-cselect__value.is-placeholder {
      color: var(--ink-faint, #8c8c8c);
    }
    .ent-cselect .ent-select-chevron {
      flex: 0 0 auto;
      display: inline-flex;
      pointer-events: none;
      color: var(--ink-mute, #595959);
      transition: transform 0.18s cubic-bezier(0.23, 1, 0.32, 1);
    }
    .ent-cselect__trigger[aria-expanded='true'] .ent-select-chevron {
      transform: rotate(180deg);
    }
    .ent-cselect__menu {
      position: absolute;
      z-index: 30;
      top: calc(100% + 6px);
      left: 0;
      right: 0;
      margin: 0;
      padding: 6px;
      list-style: none;
      background: var(--bone, #fff);
      border: 1px solid var(--line, #d9d9d9);
      border-radius: 12px;
      box-shadow: 0 20px 40px -20px rgba(38, 38, 38, 0.28);
      max-height: 264px;
      overflow-y: auto;
    }
    .ent-cselect__menu[hidden] {
      display: none;
    }
    .ent-cselect__opt {
      padding: 9px 12px;
      border-radius: 8px;
      font-size: 14px;
      line-height: 1.4;
      color: var(--ink-soft, #434343);
      cursor: pointer;
      transition: background 0.12s ease, color 0.12s ease;
    }
    .ent-cselect__opt:hover,
    .ent-cselect__opt:focus-visible {
      outline: none;
      background: var(--paper, #fafafa);
      color: var(--ink, #262626);
    }
    .ent-cselect__opt[aria-selected='true'] {
      color: var(--olive, #218c00);
      font-weight: 600;
      background: color-mix(in oklab, var(--bone), var(--coral) 14%);
    }
    .ent-submit {
      margin-top: 4px;
      width: 100%;
      justify-content: center;
    }
    .ent-submit:disabled {
      opacity: 0.6;
      cursor: progress;
    }
    .ent-privacy {
      margin: 0;
      font-size: 12px;
      line-height: 1.5;
      color: var(--ink-faint, #8c8c8c);
      text-align: center;
    }
    .ent-error {
      margin: 0;
      font-size: 13px;
      line-height: 1.5;
      color: #c0392b;
      text-align: center;
    }

    /* ---------- success ---------- */
    .ent-success {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 12px;
      padding: 28px 8px;
    }
    .ent-success:not([hidden]) {
      display: flex;
    }
    .ent-success__tick {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 52px;
      height: 52px;
      border-radius: 999px;
      background: color-mix(in oklab, var(--bone), var(--coral) 22%);
      color: var(--olive, #218c00);
    }
    .ent-success__title {
      margin: 0;
      font-size: 22px;
      font-weight: 700;
      color: var(--ink, #262626);
    }
    .ent-success__body {
      margin: 0;
      max-width: 320px;
      font-size: 15px;
      line-height: 1.6;
      color: var(--ink-soft, #434343);
    }

    @media (max-width: 880px) {
      .ent-page {
        grid-template-columns: 1fr;
        gap: 40px;
      }
      .ent-h1 {
        font-size: 32px;
      }
      .ent-lead {
        font-size: 16px;
      }
      .ent-demos {
        margin-top: 56px;
        padding-top: 40px;
      }
    }
    @media (max-width: 480px) {
      .ent-row {
        grid-template-columns: 1fr;
      }
      .ent-logos__grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 22px 12px;
      }
      .ent-card {
        padding: 24px;
      }
    }
  </style>
</Layout>
